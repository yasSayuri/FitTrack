<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_premium"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Perfil"
        android:textColor="@color/purple_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center"/>

    <EditText
        android:id="@+id/edtEditNome"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Nome completo"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtEditUsuario"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Usuário (sem @)"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtEditIdade"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Idade"
        android:inputType="number"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtEditPeso"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Peso (kg)"
        android:inputType="numberDecimal"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtEditAltura"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Altura (m)"
        android:inputType="numberDecimal"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnCancelarEdicao"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Cancelar"
            android:backgroundTint="@color/bg_dark"
            android:textColor="@color/text_hint"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnAtualizarPerfil"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Atualizar"
            android:backgroundTint="@color/purple_primary"
            android:textColor="@color/text_white"/>
    </LinearLayout>

</LinearLayout>