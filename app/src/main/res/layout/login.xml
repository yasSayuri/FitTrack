<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen">

    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="bottom|center_horizontal"
        android:background="#332A0050" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="42dp"
        android:paddingBottom="32dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="36dp">

            <ImageView
                android:id="@+id/btnVoltarLogin"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/electric_violet"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_training"
                app:tint="@color/electric_violet" />

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:layout_marginBottom="28dp" />

        <EditText
            android:id="@+id/edtEmailLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Digite seu e-mail"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/electric_violet"
            android:layout_marginBottom="10dp"
            android:inputType="textEmailAddress"
            android:textSize="14sp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp" />

        <EditText
            android:id="@+id/edtPasswordLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Senha"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/electric_violet"
            android:layout_marginBottom="30dp"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDoLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="LOGAR"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/text_white"
            android:background="@drawable/bg_auth_button"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:stateListAnimator="@null" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Não tem uma conta?"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="22dp" />

        <TextView
            android:id="@+id/txtIrParaCadastro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadastre-se"
            android:textColor="@color/electric_violet"
            android:textStyle="bold"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>