<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/telaIntro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="36dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/onboarding_intro" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Você é novo por aqui!"
                android:textColor="@color/text_white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vamos montar seu perfil para personalizar sua jornada de treinos."
                android:textColor="@color/text_hint"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/btnComecarJornada"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Começar jornada!"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_white"
                android:backgroundTint="@color/purple_primary"
                app:cornerRadius="16dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/telaGenero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="330dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/onboarding_genero" />

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="26dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/purple_primary"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="4dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seu gênero é"
                android:textColor="@color/text_white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="start"
                android:layout_marginBottom="22dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:background="@android:color/transparent"
                android:layout_marginBottom="34dp">

                <Button
                    android:id="@+id/btnMasculino"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Masculino"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:backgroundTint="@color/bg_dark"
                    android:layout_marginEnd="6dp"
                    app:cornerRadius="14dp" />

                <Button
                    android:id="@+id/btnFeminino"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Feminino"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:backgroundTint="@color/purple_primary"
                    android:layout_marginStart="6dp"
                    app:cornerRadius="14dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnVoltarGenero"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="Voltar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:backgroundTint="@color/bg_gray"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btnProximoGenero"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="Próximo"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:backgroundTint="@color/purple_primary"
                    android:layout_marginStart="8dp"
                    app:cornerRadius="16dp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/telaDados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="330dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/onboarding_dados" />

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="26dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/purple_primary"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="4dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seus dados físicos"
                android:textColor="@color/text_white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="start"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Informe seu peso e altura para acompanhar melhor sua evolução."
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:gravity="start"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Peso"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="start"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edtPeso"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ex: 70.5 kg"
                android:inputType="numberDecimal"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_hint"
                android:backgroundTint="@color/purple_primary"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Altura"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="start"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edtAltura"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ex: 1.70 m"
                android:inputType="numberDecimal"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_hint"
                android:backgroundTint="@color/purple_primary"
                android:layout_marginBottom="34dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnVoltarDados"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="Voltar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:backgroundTint="@color/bg_gray"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btnProximoDados"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="Próximo"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:backgroundTint="@color/purple_primary"
                    android:layout_marginStart="8dp"
                    app:cornerRadius="16dp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/telaObjetivo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="330dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/onboarding_objetivo" />

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="26dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/purple_primary"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="4dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seu objetivo é"
                android:textColor="@color/text_white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="start"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/edtObjetivo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ex: emagrecer, hipertrofia..."
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_hint"
                android:backgroundTint="@color/purple_primary"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Como é seu ritmo de atividade?"
                android:textColor="@color/text_white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="start"
                android:layout_marginBottom="18dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:layout_marginBottom="34dp">

                <Button
                    android:id="@+id/btnAtividadeLeve"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Leve"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:backgroundTint="@color/purple_primary"
                    android:layout_marginEnd="5dp"
                    app:cornerRadius="14dp" />

                <Button
                    android:id="@+id/btnAtividadeModerada"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Médio"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:backgroundTint="@color/bg_dark"
                    android:layout_marginHorizontal="5dp"
                    app:cornerRadius="14dp" />

                <Button
                    android:id="@+id/btnAtividadeIntensa"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Intenso"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:backgroundTint="@color/bg_dark"
                    android:layout_marginStart="5dp"
                    app:cornerRadius="14dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnVoltarObjetivo"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="Voltar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:backgroundTint="@color/bg_gray"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btnProximoObjetivo"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="Próximo"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:backgroundTint="@color/purple_primary"
                    android:layout_marginStart="8dp"
                    app:cornerRadius="16dp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/telaFinal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:layout_marginBottom="30dp"
                app:cardCornerRadius="36dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/onboarding_final" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Você está pronto!"
                android:textColor="@color/text_white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bora treinar?"
                android:textColor="@color/purple_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="34dp" />

            <Button
                android:id="@+id/btnFinalizarOnboarding"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Bora começar!"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_white"
                android:backgroundTint="@color/purple_primary"
                app:cornerRadius="16dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>