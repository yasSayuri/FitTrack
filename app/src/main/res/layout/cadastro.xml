<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_degrade_roxo">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:id="@+id/btnVoltarCadastro"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_white"
            android:layout_marginBottom="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cadastro"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/edtNameSignup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Nome completo"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/purple_primary"
            android:layout_marginBottom="16dp"
            android:inputType="textPersonName"/>

        <EditText
            android:id="@+id/edtUsernameSignup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Usuário"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/purple_primary"
            android:layout_marginBottom="16dp"
            android:inputType="text"/>

        <EditText
            android:id="@+id/edtEmailSignup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="E-mail"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/purple_primary"
            android:layout_marginBottom="16dp"
            android:inputType="textEmailAddress"/>

        <EditText
            android:id="@+id/edtCpfSignup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="CPF"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/purple_primary"
            android:layout_marginBottom="16dp"
            android:inputType="number"/>

        <EditText
            android:id="@+id/edtBirthdaySignup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Data de nascimento"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/purple_primary"
            android:layout_marginBottom="16dp"
            android:inputType="number"/>

        <EditText
            android:id="@+id/edtPasswordSignup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Senha"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/purple_primary"
            android:layout_marginBottom="32dp"
            android:inputType="textPassword"/>

        <Button
            android:id="@+id/btnDoSignup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Cadastrar"
            android:backgroundTint="@color/selector_btn_roxo"
            android:textColor="@color/text_white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Já tem uma conta? "
                android:textColor="@color/text_hint"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/txtIrParaLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Faça o Login"
                android:textColor="@color/purple_primary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>