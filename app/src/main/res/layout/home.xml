<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:id="@+id/headerHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olá, User"
            android:textColor="@color/text_white"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pronta para o treino?"
            android:textColor="@color/text_hint"
            android:textSize="14sp"/>
    </LinearLayout>

    <View
        android:id="@+id/divisoriaHome"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@color/purple_primary"
        android:layout_marginTop="16dp"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerHome" />

    <LinearLayout
        android:id="@+id/dashboardContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@+id/divisoriaHome"
        app:layout_constraintBottom_toTopOf="@+id/bottomBarContainer">

        <Button
            android:id="@+id/btnNovoTreino"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="NOVO TREINO +"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="@color/purple_primary"
            android:textColor="@color/text_white"
            android:layout_marginBottom="16dp"
            app:cornerRadius="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_gray"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Horas Treinadas"
                        android:textColor="@color/text_white"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6h 30m"
                            android:textColor="@color/purple_primary"
                            android:textSize="28sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+2h vs semana passada"
                            android:textColor="@color/text_hint"
                            android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_gray"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Treinos"
                        android:textColor="@color/text_white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_gravity="start"
                        android:layout_marginBottom="4dp"/>

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/bg_circulo_roxo"
                        android:backgroundTint="#4A148C"
                        android:progress="60"
                        android:progressDrawable="@drawable/bg_circulo_roxo"
                        android:rotation="-90" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="@color/purple_primary" android:layout_marginEnd="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Academia" android:textSize="10sp" android:textColor="@color/text_hint"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="2dp">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="#4A148C" android:layout_marginEnd="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cardio" android:textSize="10sp" android:textColor="@color/text_hint"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="2dp">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="#B39DDB" android:layout_marginEnd="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Muay Thai" android:textSize="10sp" android:textColor="@color/text_hint"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="2dp">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="#9575CD" android:layout_marginEnd="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pilates" android:textSize="10sp" android:textColor="@color/text_hint"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.2"
            app:cardBackgroundColor="@color/bg_gray"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dias Treinados"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:paddingTop="8dp">

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="20dp" android:layout_height="30dp" android:background="#9575CD" app:cornerRadius="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D" android:textSize="10sp" android:textColor="@color/text_hint" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="20dp" android:layout_height="50dp" android:background="@color/purple_primary" app:cornerRadius="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textSize="10sp" android:textColor="@color/text_hint" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="20dp" android:layout_height="20dp" android:background="#B39DDB" app:cornerRadius="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textSize="10sp" android:textColor="@color/text_hint" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="20dp" android:layout_height="60dp" android:background="#6A1B9A" app:cornerRadius="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Q" android:textSize="10sp" android:textColor="@color/text_hint" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="20dp" android:layout_height="45dp" android:background="#7E57C2" app:cornerRadius="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Q" android:textSize="10sp" android:textColor="@color/text_hint" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="20dp" android:layout_height="10dp" android:background="#D1C4E9" app:cornerRadius="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textSize="10sp" android:textColor="@color/text_hint" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                        <View android:layout_width="20dp" android:layout_height="40dp" android:background="@color/purple_primary" app:cornerRadius="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textSize="10sp" android:textColor="@color/text_hint" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/divisoriaHome"
        app:layout_constraintBottom_toTopOf="@+id/bottomBarContainer" />

    <androidx.cardview.widget.CardView
        android:id="@+id/bottomBarContainer"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:cardBackgroundColor="@color/bg_gray"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/iconesContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/nav_historico"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:src="@drawable/ic_history"
                app:tint="@color/text_hint"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"/>

            <ImageView
                android:id="@+id/nav_treinos"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:src="@drawable/ic_training"
                app:tint="@color/text_hint"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"/>

            <ImageView
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:src="@drawable/ic_home"
                app:tint="@color/purple_primary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"/>

            <ImageView
                android:id="@+id/nav_perfil"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:src="@drawable/ic_profile"
                app:tint="@color/text_hint"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"/>

            <ImageView
                android:id="@+id/nav_config"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:src="@drawable/ic_settings"
                app:tint="@color/text_hint"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>