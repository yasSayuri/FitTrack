<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:id="@+id/headerHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="48dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olá, User"
            android:textColor="@color/text_white"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pronta para o treino?"
            android:textColor="@color/text_hint"
            android:textSize="14sp"/>
    </LinearLayout>

    <View
        android:id="@+id/divisoriaHome"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@color/purple_primary"
        android:layout_marginTop="24dp"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerHome" />

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@+id/divisoriaHome"
        app:layout_constraintBottom_toTopOf="@+id/bottomBarContainer" />

    <androidx.cardview.widget.CardView
        android:id="@+id/bottomBarContainer"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:cardBackgroundColor="@color/bg_gray"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/bolaRoxa"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_circulo_roxo"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/iconesContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:elevation="2dp">

                <ImageView
                    android:id="@+id/nav_historico"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_history"
                    app:tint="@color/text_hint"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"/>

                <ImageView
                    android:id="@+id/nav_treinos"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_training"
                    app:tint="@color/text_hint"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"/>

                <ImageView
                    android:id="@+id/nav_home"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_home"
                    app:tint="@color/text_white"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"/>

                <ImageView
                    android:id="@+id/nav_perfil"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/text_hint"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"/>

                <ImageView
                    android:id="@+id/nav_config"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/text_hint"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>