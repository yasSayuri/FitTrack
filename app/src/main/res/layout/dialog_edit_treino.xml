<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_premium"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Treino"
        android:textColor="@color/purple_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center"/>

    <EditText
        android:id="@+id/edtEditTipo"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Tipo"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtEditDuracao"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Duração (h)"
        android:inputType="number"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtEditCalorias"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Calorias"
        android:inputType="number"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtEditData"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Data (dd/mm/aaaa)"
        android:inputType="date"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtEditDescricao"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Descrição"
        android:gravity="top|start"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_dark"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnCancelarEditTreino"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Cancelar"
            android:backgroundTint="@color/bg_dark"
            android:textColor="@color/text_hint"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSalvarEditTreino"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Salvar"
            android:backgroundTint="@color/purple_primary"
            android:textColor="@color/text_white"/>
    </LinearLayout>
</LinearLayout>