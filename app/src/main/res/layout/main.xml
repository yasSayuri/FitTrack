<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/main_bg"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="40dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FitTrack"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:textAlignment="center"
            android:layout_marginBottom="1dp" />

        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/logo_fittrack_neon"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Planejamento e progresso\nem um só lugar"
            android:textSize="20sp"
            android:textColor="@color/text_white"
            android:textAlignment="center"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="32dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLoginMain"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:text="ENTRAR"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="@color/text_white"
            android:background="@drawable/bg_btn_main_login"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:layout_marginBottom="16dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSignupMain"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:text="CADASTRE-SE"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="@color/turbo"
            android:background="@drawable/bg_btn_main_signup"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:stateListAnimator="@null" />

    </LinearLayout>

</FrameLayout>